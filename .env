# Crisis-Guard AI — Environment Variables
# Copy this file to .env and fill in your values

# ── News API Keys (for Globe Dashboard) ──────────────────────────────────────
# Get a free key at https://newsapi.org
VITE_NEWS_API_KEY=

# Get a free key at https://gnews.io (100 req/day free)
VITE_GNEWS_API_KEY=0980d420b92494a374333df4bec2eceb

# ── Backend API URL (for Forensics features) ──────────────────────────────────
# Points to the Node.js backend. In dev, Vite proxy handles /api automatically.
# In production, set this to your deployed backend URL.
VITE_API_BASE_URL=http://localhost:5000/api

# ── Backend (Node.js) ─────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/crisisguard
JWT_SECRET=your_jwt_secret_here
PORT=5000
NODE_ENV=development
AI_SERVICE_URL=http://localhost:8000

# Optional: NewsAPI key for backend chatbot news fetching
NEWS_API_KEY=
GEMINI_API_KEY=AIzaSyANVLGbHSa_bDCX3sS4vWkJSY5CRK2ndn0

# ── AI Service (Python FastAPI) ───────────────────────────────────────────────
# No config needed for local dev — runs on port 8000 by default
